# Compose
NODE_ENV=production

# Published ports on the host
FRONTEND_PUBLISHED_PORT=8080
BACKEND_PUBLISHED_PORT=3000
POSTGRES_PUBLISHED_PORT=5433
REDIS_PUBLISHED_PORT=6379

# Frontend / backend routing
VITE_API_BASE_URL=/api
FRONTEND_ORIGIN=http://localhost:8080
BACKEND_HOST=0.0.0.0
REFRESH_COOKIE_PATH=/api/auth

# Postgres
POSTGRES_DB=tradevise
POSTGRES_USER=tradevise
POSTGRES_PASSWORD=change-me-postgres-password

# App connection strings
DATABASE_URL=postgresql://tradevise:change-me-postgres-password@postgres:5432/tradevise
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# JWT secrets
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
