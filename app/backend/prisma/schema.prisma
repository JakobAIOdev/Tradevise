generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  username           String   @unique
  passwordHash       String
  hashedRefreshToken String?
  tokenVersion       Int      @default(0)
  activePortfolioId  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  activePortfolio Portfolio?     @relation("ActivePortfolio", fields: [activePortfolioId], references: [id], onDelete: SetNull)
  transactions    Transaction[]
  portfolios      Portfolio[]    @relation("UserPortfolios")
  ownedGroups      Group[]            @relation("GroupOwner")
  groupMemberships GroupMember[]      @relation("GroupMemberUser")
}

model PriceIntraday {
  symbol String   @db.Text
  time   DateTime @db.Timestamptz
  price  Decimal  @db.Decimal(14, 4)

  @@id([symbol, time])
  @@map("prices_intraday")
}

model PriceDaily {
  symbol String   @db.Text
  date   DateTime @db.Date
  price  Decimal  @db.Decimal(14, 4)

  @@id([symbol, date])
  @@map("prices_daily")
}

model TrackedSymbol {
  symbol            String    @id @db.Text
  name              String?   @db.Text
  currency          String?   @db.Text
  lastIntradayFetch DateTime? @map("last_intraday_fetch") @db.Timestamptz
  lastWeeklyFetch   DateTime? @map("last_weekly_fetch") @db.Timestamptz

  @@map("tracked_symbols")
}

model StockMeta {
  symbol           String   @id @db.Text
  name             String?  @db.Text
  currency         String?  @db.Text
  exchange         String?  @db.Text
  previousClose    Decimal? @map("previous_close") @db.Decimal(14, 4)
  dayHigh          Decimal? @map("day_high") @db.Decimal(14, 4)
  dayLow           Decimal? @map("day_low") @db.Decimal(14, 4)
  fiftyTwoWeekHigh Decimal? @map("fifty_two_week_high") @db.Decimal(14, 4)
  fiftyTwoWeekLow  Decimal? @map("fifty_two_week_low") @db.Decimal(14, 4)
  volume           Int?
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("stock_meta")
}

model PortfolioHolding {
  id           String   @id @default(cuid())
  portfolioId  String
  symbol       String
  quantity     Decimal  @db.Decimal(18, 6)
  averagePrice Decimal  @db.Decimal(14, 4)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, symbol])
}

model Transaction {
  id          String    @id @default(cuid())
  userId      String
  portfolioId String
  symbol      String
  type        TradeType
  quantity    Decimal   @db.Decimal(18, 6)
  price       Decimal   @db.Decimal(14, 4)
  total       Decimal   @db.Decimal(18, 4)
  createdAt   DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId])
}

enum TradeType {
  BUY
  SELL
}

model Portfolio {
  id        String   @id @default(cuid())
  userId    String
  name      String
  isDefault Boolean  @default(false)
  cash      Decimal  @default(10000.00) @db.Decimal(18, 4)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activeForUsers User[]             @relation("ActivePortfolio")
  holdings       PortfolioHolding[]
  transactions   Transaction[]
  watchlistItems WatchlistItem[]
  groupMembers   GroupMember[]
  user           User               @relation("UserPortfolios", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model WatchlistItem {
  id        String   @id @default(cuid())
  portfolioId String
  symbol    String   @db.Text
  createdAt DateTime @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, symbol])
  @@index([symbol])
  @@map("watchlist_items")
}

model Group {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  ownerId   String
  createdAt DateTime @default(now())

  owner   User          @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members GroupMember[]
}

model GroupMember {
  id          String    @id @default(uuid())
  groupId     String
  userId      String
  portfolioId String
  role        GroupRole @default(MEMBER)
  joinedAt    DateTime  @default(now())

  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  user      User      @relation("GroupMemberUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, portfolioId])
  @@index([portfolioId])
}

enum GroupRole {
  OWNER
  MEMBER
}
