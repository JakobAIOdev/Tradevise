generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  username           String   @unique
  passwordHash       String
  hashedRefreshToken String?
  tokenVersion       Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  holdings     PortfolioHolding[]
  transactions Transaction[]
  portfolios   Portfolio[]
}

model PriceIntraday {
  symbol String   @db.Text
  time   DateTime @db.Timestamptz
  price  Decimal  @db.Decimal(14, 4)

  @@id([symbol, time])
  @@map("prices_intraday")
}

model PriceWeekly {
  symbol String   @db.Text
  date   DateTime @db.Date
  price  Decimal  @db.Decimal(14, 4)

  @@id([symbol, date])
  @@map("prices_weekly")
}

model TrackedSymbol {
  symbol            String    @id @db.Text
  name              String?   @db.Text
  currency          String?   @db.Text
  bootstrapStatus   String?   @default("PENDING") @map("bootstrap_status") @db.Text
  bootstrappedAt    DateTime? @map("bootstrapped_at") @db.Timestamptz
  lastIntradayFetch DateTime? @map("last_intraday_fetch") @db.Timestamptz
  lastWeeklyFetch   DateTime? @map("last_weekly_fetch") @db.Timestamptz

  @@map("tracked_symbols")
}

model PortfolioHolding {
  id           String   @id @default(cuid())
  userId       String
  symbol       String
  quantity     Decimal  @db.Decimal(18, 6)
  averagePrice Decimal  @db.Decimal(14, 4)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
}

model Transaction {
  id        String    @id @default(cuid())
  userId    String
  symbol    String
  type      TradeType
  quantity  Decimal   @db.Decimal(18, 6)
  price     Decimal   @db.Decimal(14, 4)
  total     Decimal   @db.Decimal(18, 4)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum TradeType {
  BUY
  SELL
}

model Portfolio {
  id        String   @id @default(cuid())
  userId    String   @unique
  cash      Decimal  @default(10000.00) @db.Decimal(18, 4)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
